# Example certificaat.env for local dist usage
# Copy this file to "certificaat.env" and fill in real secrets/paths.
#
# Networking4all specific notes:
# 1) Create a DNS CNAME record for every root domain you request certs for:
#      Name:  _dnsauth
#      Type:  CNAME
#      Value: <your unique value from the Networking4all ACME credentials page>
#    Example value format: 4b121cd89407a55a7b26e377ca2dd92f.n4all.eu
#
# 2) ACME_DIRECTORY uses this format for production:
#      https://acme.networking4all.com/<PRODUCT>
#    Example for DV: https://acme.networking4all.com/dv
#    Test environment format:
#      https://test-acme.networking4all.com/<PRODUCT>
#
# 3) When invoking simple-acme (wacs), use --validation none for this provider.
#    Example:
#      wacs --accepttos --baseuri <SELECTED-SERVER> --eab-key-identifier <YOUR-KID> --eab-key <YOUR-SECRET> --validation none

# Required ACME values
ACME_DIRECTORY=https://acme.networking4all.com/dv
ACME_KID=your-eab-kid
ACME_HMAC_SECRET=your-eab-hmac-secret
DOMAINS=example.com,www.example.com
ACME_SCRIPT_PATH=.\\Scripts\\New-CertificaatDropFile.ps1

# Required certificaat paths/api key
CERTIFICAAT_CONFIG_DIR=.\\config
CERTIFICAAT_DROP_DIR=.\\drop
CERTIFICAAT_STATE_DIR=.\\state
CERTIFICAAT_LOG_DIR=.\\log
CERTIFICAAT_API_KEY=replace-with-strong-api-key

# Optional provider hint (not read by the loader, for operator reference only)
N4ALL_DNSAUTH_CNAME_TARGET=your-generated-token.n4all.eu

# Optional settings (defaults shown)
CERTIFICAAT_VERIFY_MAX_ATTEMPTS=3
CERTIFICAAT_ACTIVATE_TIMEOUT_MS=120000
CERTIFICAAT_DEFAULT_FANOUT=fail-fast
CERTIFICAAT_SKIP_TLS_CHECK=0
CERTIFICAAT_RETRY_MAX_ATTEMPTS=3
CERTIFICAAT_RETRY_BACKOFF_MS=1000
CERTIFICAAT_HTTP_ENABLED=0
CERTIFICAAT_HTTP_PREFIX=http://localhost:8443/
CERTIFICAAT_DISABLE_ROLLBACK=0
CERTIFICAAT_HTTP_HOST=127.0.0.1
CERTIFICAAT_HTTP_PORT=8088
