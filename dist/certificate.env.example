# Phase 1 bootstrap certificate.env (used only for initial setup).
# Runtime state lives in:
#   %ProgramData%\simple-acme\settings.json
#   %ProgramData%\simple-acme\*.renewal.json

ACME_PROVIDER=letsencrypt
ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
ACME_REQUIRES_EAB=0
ACME_KID=
ACME_HMAC_SECRET=
DOMAINS=example.com,www.example.com
TARGET_SYSTEM=rds
TARGET_LOCATION=this-server

# Optional bootstrap values
ACME_ACCOUNT_NAME=
ACME_WACS_PATH=
ACME_CSR_ALGORITHM=ec
ACME_PRIVATEKEY_EXPORTABLE=false
